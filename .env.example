# Environment Configuration
# Copy to .env and fill in your values

# ============================================
# DATABASE CONFIGURATION
# ============================================
MONGO_URI=mongodb://mongo:27017/polybazar
POSTGRES_URL=jdbc:postgresql://postgres:5432/polybazar
POSTGRES_USER=polybazar
POSTGRES_PASSWORD=polybazar_dev_password_change_me

# ============================================
# AUTHENTICATION & SECURITY
# ============================================
JWT_SECRET=your_256_bit_secret_key_here_must_be_at_least_32_chars
JWT_ACCESS_EXPIRY=900000
JWT_REFRESH_EXPIRY=1209600000

# KYC Encryption (AES-256 key, base64 encoded)
KYC_ENCRYPTION_KEY=your_256_bit_secret_key_here_must_be_at_least_32_chars

# ============================================
# CLOUD STORAGE
# ============================================
CLOUDINARY_CLOUD_NAME=demo
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Azure Blob Storage (optional)
AZURE_STORAGE_CONN_STRING=

# ============================================
# ML SERVICES CONFIGURATION
# ============================================
ML_MODEL_PATH=/app/models
FAISS_INDEX_PATH=/app/data/faiss.index
CHROMA_PATH=/app/data/chroma

# Vector DB: 'faiss' or 'chroma'
VECTOR_DB_TYPE=faiss

# Embedding model: 'local' (sentence-transformers) or 'openai'
EMBEDDING_MODEL=local
OPENAI_API_KEY=

# ============================================
# EXTERNAL SERVICES
# ============================================
# PhonePe/PayU Payment Gateway
PHONEPAY_MERCHANT_ID=
PHONEPAY_SALT_KEY=
PHONEPAY_CALLBACK_URL=

# ============================================
# APPLICATION URLS
# ============================================
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8080
ML_SERVICE_URL=http://localhost:8000

# CORS Allowed Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000

# ============================================
# DEPLOYMENT (Production Only)
# ============================================
RENDER_API_KEY=
DO_API_TOKEN=
AZURE_SUBSCRIPTION_ID=

# ============================================
# REDIS (Optional - for rate limiting/caching)
# ============================================
REDIS_URL=redis://redis:6379
